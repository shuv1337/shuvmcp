{
  "name": "mcp-apps-hello",
  "version": "0.1.0",
  "description": "A minimal MCP Apps (io.modelcontextprotocol/ui) interactive-UI server — the native TS analog of a FastMCP Prefab app.",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/widget.html dist/widget.html",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "serve": "tsx src/serve.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
