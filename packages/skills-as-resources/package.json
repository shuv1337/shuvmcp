{
  "name": "skills-as-resources",
  "version": "0.1.0",
  "description": "Reference implementation of the Skills-as-Resources MCP wire spec (server + client) on @modelcontextprotocol/sdk.",
  "type": "module",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "serve": "tsx src/examples/serve.ts"
  },
  "keywords": ["mcp", "model-context-protocol", "skills", "agent-skills", "fastmcp"],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
